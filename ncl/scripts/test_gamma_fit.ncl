    ; dsizes_X = dimsizes(X)
    ; X!0    = "dim0"
    ; X&dim0 = ispan(0,dsizes_X-1,1)
    ; printVarSummary(X)

    nvals    = 10000
    nor      = random_normal(0.0, 1.0, nvals)
    nor!0    = "dim0"
    nor&dim0 = ispan(0,nvals-1,1)

    X  = dist_mixed_gamma_Pinv(dist_ugauss_P(nor),0.85,1.5,5.0)
    printVarSummary(X)

    print("C mixed_gamma fit")
    X_p   := fit_dist_Lst(X,"mixed_gamma","dim0")
    printVarSummary(X_p)
    print(X_p[0])
    print(X_p[1])
    print(X_p[2])
    X_P   := dist_P(X,X_p,"mixed_gamma")
    printVarSummary(X_P)
    X_z   := dist_ugauss_Pinv(X_P)
    printVarSummary(X_z)
    print("")
    
    ; print(X+" "+X_P+" "+X_z)

    print("C gauss fit")
    X_p   := fit_dist_Lst(X,"gauss","dim0")
    printVarSummary(X_p)
    print(X_p[0])
    print(X_p[1])
    X_P   := dist_P(X,X_p,"gauss")
    printVarSummary(X_P)
    X_z   := dist_ugauss_Pinv(X_P)
    printVarSummary(X_z)
    print("")
    
    ; print(X+" "+X_P+" "+X_z)

    X_p_mle = named_extval_mlegam(X,"dim0")
    print(X_p_mle)
    print("")


    X_p_gamfit = named_gamfit(X,"dim0")
    print(X_p_gamfit)
    print("")
end
